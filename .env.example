# Backend API Configuration
VITE_API_BASE_URL="/api"

# Back4App Dashboard → App Settings → Security & Keys (JavaScript key)
VITE_BACK4APP_APP_ID="your-app-id"
VITE_BACK4APP_JS_KEY="your-javascript-key"
# Optional; default is https://parseapi.back4app.com
# VITE_BACK4APP_SERVER_URL="https://parseapi.back4app.com"

# Legacy Supabase config (not used)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your-publishable-key"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key-legacy-optional"
VITE_SUPABASE_ANON_KEY="your-anon-key-optional-if-publishable-key-is-used"
VITE_SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-only-for-server-side-operations"
